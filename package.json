{
  "name": "agentic-browser",
  "version": "1.0.0",
  "description": "A desktop application that gives an AI agent its own real browser — one it can see, read, and operate the way a human would, with a visible, permissioned, human-supervisable interface.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "keywords": [
    "agentic-browser",
    "electron",
    "ai-agent",
    "browser-automation"
  ],
  "author": "Shubham",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron": "^43.0.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
